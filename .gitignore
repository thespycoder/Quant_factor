# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/

# Environment / secrets
.env
*keys*.txt
*secrets*.txt

# Data folder contents (keep .gitkeep markers)
data/raw_filings/*
data/prices/*
!data/raw_filings/.gitkeep
!data/prices/.gitkeep

# Binary / columnar data files
*.parquet
*.db
*.sqlite
*.sqlite3

# Chroma vector store
chroma/
chroma_db/

# Factor library — live data (generated; gitignored so the repo stays small)
factor_library/factors_index.parquet
factor_library/records/
factor_library/memos/
factor_library/chroma/

# Factor library snapshot — tracked for Streamlit Cloud read-only deployment.
# The dashboard reads from snapshot/ when the live factor_library/ root is absent.
# Override *.parquet above for the snapshot index only; records/ and memos/ under
# snapshot/ are plain JSON/Markdown so they are tracked without extra rules.
!factor_library/snapshot/
!factor_library/snapshot/factors_index.parquet

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
